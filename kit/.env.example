# Local development only. Copy to .env and keep .env unversioned.

# Required for LocalStack Pro and for LocalStack MCP.
# Never commit the real token.
LOCALSTACK_AUTH_TOKEN=replace-with-localstack-token

# Override only when you intentionally pin a LocalStack image tag.
LOCALSTACK_IMAGE=localstack/localstack-pro
LOCALSTACK_DOCKER_NAME=localstack-main
LOCALSTACK_VOLUME_DIR=.localstack/volume

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1

DEBUG=0
PERSISTENCE=1
MCP_ANALYTICS_DISABLED=1
